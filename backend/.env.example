PORT=3000
NODE_ENV=production

MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=edtech_db

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/edtech_logs

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://your-backend-domain.com/auth/github/callback

FRONTEND_URL=https://your-frontend-domain.com
FRONTEND_URLS=https://your-frontend-domain.com

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-app-password
SMTP_FROM=your-email@example.com
